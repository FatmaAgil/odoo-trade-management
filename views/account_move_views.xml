<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_inherit_trade" model="ir.ui.view">
        <field name="name">account.move.form.inherit.trade</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />

        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="before">

                <group string="Trade Accounting Information">

                    <field name="sale_order_reference" readonly="1" />

                    <field name="approval_note"
                        placeholder="Finance remarks..." />

                </group>

            </xpath>

        </field>
    </record>

</odoo>