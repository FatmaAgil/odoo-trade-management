<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_inherit_trade" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.trade</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">

            <!-- Add new fields inside form -->
            <xpath expr="//sheet" position="inside">
                <group string="Trade Management">

                    <field name="priority" />

                    <field name="trade_notes" placeholder="Trade notes..." />

                    <field name="internal_note" placeholder="Internal team notes..." />

                </group>
            </xpath>

            <!-- SMART BUTTON -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_invoice"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o">
                    <field name="invoice_count" widget="statinfo" string="Invoices" />
                </button>
            </xpath>

        </field>
    </record>

</odoo>